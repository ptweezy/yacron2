# Keep the build context small. The Rust build only needs Cargo.* and src/.
target
.git
.github
.githooks
example
pyinstaller
*.md
.editorconfig
.gitignore
.dockerignore
# stale Python artifacts (removed from the repo, ignored if present locally)
.venv
.venv314
.tox
.mypy_cache
.ruff_cache
.pytest_cache
dist
build
*.egg-info
__pycache__
*.pyc
