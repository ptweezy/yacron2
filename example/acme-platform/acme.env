# Demo env_file for the ACME cluster (referenced by backup-warehouse via
# `env_file: /config/acme.env`). Mounted read-only into every node at
# /config/acme.env. Shows how yacron2 layers a file of KEY=value pairs into a
# job's environment on top of its inline `environment:` list.
BACKUP_BUCKET=s3://acme-backups/warehouse
BACKUP_RETENTION_DAYS=30
