# Demo env_file for the Meridian grand tour (referenced by backup-warehouse via
# `env_file: /config/platform.env`). Mounted read-only into every node at
# /config/platform.env. Shows how yacron2 layers a file of KEY=value pairs onto
# a job's environment on top of its inline `environment:` list. Blank lines and
# lines starting with `#` are ignored.  [feature: env_file]
BACKUP_BUCKET=s3://meridian-backups/warehouse
BACKUP_RETENTION_DAYS=30
